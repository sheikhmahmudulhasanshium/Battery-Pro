<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_custom_range" android:textStyle="bold" android:textSize="18sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <EditText android:id="@+id/etMin" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="@string/hint_min" android:autofillHints="none" android:inputType="number" />
            <EditText android:id="@+id/etMax" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="@string/hint_max" android:autofillHints="none" android:inputType="number" />
        </LinearLayout>
        <EditText android:id="@+id/etWhatsApp" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/hint_wa" android:autofillHints="phone" android:inputType="phone" />
        <Button android:id="@+id/btnStart" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_start_sync" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_activity_report" android:textStyle="bold" android:layout_marginTop="20dp"/>
        <TextView android:id="@+id/tvLogs" android:layout_width="match_parent" android:layout_height="200dp" android:padding="10dp" android:scrollbars="vertical" />
        <Button android:id="@+id/btnClearLogs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/btn_clear_history" android:textSize="12sp" android:layout_gravity="end"/>
    </LinearLayout>
</ScrollView>